  <assessment ident="g77169024438ef9a866e21715fc2360f2" title="Section 3 Quiz - Knowledge Check: Vector Graphics and File Types in ADOBE Illustrator" external_assignment_id="62505667">
    <qtimetadata>
      <qtimetadatafield>
        <fieldlabel>cc_maxattempts</fieldlabel>
        <fieldentry>1</fieldentry>
