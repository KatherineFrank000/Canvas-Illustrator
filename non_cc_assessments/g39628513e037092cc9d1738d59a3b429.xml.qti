          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;p&gt;Which color mode is best used for web-based design?&lt;/p&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="5a44539b-5df3-40af-8f59-fb2ee5b92a6e">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;RGB&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="16bdc5e5-d136-499a-9e3c-e013e6b5db65">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;WebP&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="89786963-135b-4486-99e2-80f07914e857">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;CMYK&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="23848b5d-ab5f-476e-8f47-f65115bfd956">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;GIF&lt;/p&gt;</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">5a44539b-5df3-40af-8f59-fb2ee5b92a6e</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
