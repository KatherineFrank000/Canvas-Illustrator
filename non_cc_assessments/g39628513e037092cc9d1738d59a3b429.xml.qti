          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;p&gt;What would be the easiest way to match a web color using the ADOBE Color site?&lt;/p&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="222a0e5d-79c4-43e1-a6e1-2fe342b9f6d6">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;Enter the ratios for RGB color values.&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="258451f6-8e5d-4a5e-b31b-f5239282e671">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;Enter the HEX code.&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="60285808-2718-4a39-bf4f-9dce46a92a13">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;Use the eyedropper tool.&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="689dff64-5814-4149-9a4d-9d328a896612">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;Enter the ratios for CMYK color values.&lt;/p&gt;</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
