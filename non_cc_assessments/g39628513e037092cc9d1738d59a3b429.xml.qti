    <section ident="root_section">
      <item ident="978bffd3d735324a5952fadee4e5e443" title="Quiz #4 - Question #1">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1.0</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>4f87c837-d99a-4b9f-9194-e6bd024b7707,69f1a41a-4e49-42cb-8f72-1ac625b600fb,242f768d-e2b8-4b67-b396-2390762f12f2,d7dbf27a-7a3b-48d8-a6b9-59553c58bd91</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>assessment_question_identifierref</fieldlabel>
              <fieldentry>7d58156a3590e25e37995ce3b3eae2b1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>calculator_type</fieldlabel>
              <fieldentry>none</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;p&gt;What color set would result from the following action?&lt;/p&gt;
&lt;p&gt;Click on the fill box to bring it to the front and choose the white box with the red slash through it.&lt;/p&gt;
&lt;p&gt;Next, click the stroke box to bring it to the front and choose the color red from the Color window.&lt;/p&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="4f87c837-d99a-4b9f-9194-e6bd024b7707">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;The object would have a white fill color with a red stroke.&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="69f1a41a-4e49-42cb-8f72-1ac625b600fb">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;The object would have a red fill color with no stroke color.&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="242f768d-e2b8-4b67-b396-2390762f12f2">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;The object would have a no fill color with a red stroke.&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="d7dbf27a-7a3b-48d8-a6b9-59553c58bd91">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;The object would have a white fill color with no stroke color.&lt;/p&gt;</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">242f768d-e2b8-4b67-b396-2390762f12f2</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="3919f059a1d9c734d8d53d7d042c613a" title="Quiz #4 - Question #2">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1.0</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>5a44539b-5df3-40af-8f59-fb2ee5b92a6e,16bdc5e5-d136-499a-9e3c-e013e6b5db65,89786963-135b-4486-99e2-80f07914e857,23848b5d-ab5f-476e-8f47-f65115bfd956</fieldentry>
            </qtimetadatafield>
