              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>222a0e5d-79c4-43e1-a6e1-2fe342b9f6d6,258451f6-8e5d-4a5e-b31b-f5239282e671,60285808-2718-4a39-bf4f-9dce46a92a13,689dff64-5814-4149-9a4d-9d328a896612</fieldentry>
